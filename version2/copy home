    <script>
        // Tools Data
        const tools = [
            { id: 'merge', name: 'Merge PDF', icon: 'fa-object-group', desc: 'Combine PDFs in the order you want with the easiest PDF merger available.', category: 'organize', color: 'bg-blue-500' },
            { id: 'split', name: 'Split PDF', icon: 'fa-cut', desc: 'Separate one page or a whole set for easy conversion into independent PDF files.', category: 'organize', color: 'bg-blue-500' },
            { id: 'compress', name: 'Compress PDF', icon: 'fa-compress-alt', desc: 'Reduce file size while optimizing for maximal PDF quality.', category: 'optimize', color: 'bg-green-500' },
            { id: 'pdf-to-word', name: 'PDF to Word', icon: 'fa-file-word', desc: 'Easily convert your PDF files into easy to edit DOC and DOCX documents.', category: 'convert', color: 'bg-blue-700', popular: true },
            { id: 'pdf-to-powerpoint', name: 'PDF to PowerPoint', icon: 'fa-file-powerpoint', desc: 'Turn your PDF files into easy to edit PPT and PPTX slideshows.', category: 'convert', color: 'bg-orange-500' },
            { id: 'pdf-to-excel', name: 'PDF to Excel', icon: 'fa-file-excel', desc: 'Pull data straight from PDFs into Excel spreadsheets in a few short seconds.', category: 'convert', color: 'bg-green-600' },
            { id: 'word-to-pdf', name: 'Word to PDF', icon: 'fa-file-pdf', desc: 'Make DOC and DOCX files easy to read by converting them to PDF.', category: 'convert', color: 'bg-blue-600' },
            { id: 'powerpoint-to-pdf', name: 'PowerPoint to PDF', icon: 'fa-file-pdf', desc: 'Make PPT and PPTX slideshows easy to view by converting them to PDF.', category: 'convert', color: 'bg-red-500' },
            { id: 'excel-to-pdf', name: 'Excel to PDF', icon: 'fa-file-pdf', desc: 'Make EXCEL spreadsheets easy to read by converting them to PDF.', category: 'convert', color: 'bg-green-500' },
            { id: 'edit', name: 'Edit PDF', icon: 'fa-edit', desc: 'Add text, images, shapes or freehand annotations to a PDF document.', category: 'edit', color: 'bg-purple-500', new: true },
            { id: 'pdf-to-jpg', name: 'PDF to JPG', icon: 'fa-file-image', desc: 'Convert each PDF page into a JPG or extract all images contained in a PDF.', category: 'convert', color: 'bg-pink-500' },
            { id: 'jpg-to-pdf', name: 'JPG to PDF', icon: 'fa-images', desc: 'Convert JPG images to PDF in seconds. Easily adjust orientation and margins.', category: 'convert', color: 'bg-indigo-500' },
            { id: 'sign', name: 'Sign PDF', icon: 'fa-signature', desc: 'Sign yourself or request electronic signatures from others.', category: 'edit', color: 'bg-blue-400' },
            { id: 'watermark', name: 'Watermark', icon: 'fa-stamp', desc: 'Stamp an image or text over your PDF in seconds. Choose typography, transparency and position.', category: 'edit', color: 'bg-yellow-500' },
            { id: 'rotate', name: 'Rotate PDF', icon: 'fa-sync-alt', desc: 'Rotate your PDFs the way you need them. You can even rotate multiple PDFs at once!', category: 'organize', color: 'bg-teal-500' },
            { id: 'unlock', name: 'Unlock PDF', icon: 'fa-unlock', desc: 'Remove PDF password security, giving you the freedom to use your PDFs as you want.', category: 'security', color: 'bg-gray-600' },
            { id: 'protect', name: 'Protect PDF', icon: 'fa-lock', desc: 'Protect PDF files with a password. Encrypt PDF documents to prevent unauthorized access.', category: 'security', color: 'bg-red-600' },
            { id: 'organize', name: 'Organize PDF', icon: 'fa-th-large', desc: 'Sort pages of your PDF file however you like. Delete or add PDF pages at your convenience.', category: 'organize', color: 'bg-cyan-500' },
            { id: 'repair', name: 'Repair PDF', icon: 'fa-tools', desc: 'Repair a damaged PDF and recover data from corrupt PDF. Fix PDF files with our Repair tool.', category: 'optimize', color: 'bg-green-700' },
            { id: 'ocr', name: 'OCR PDF', icon: 'fa-search', desc: 'Easily convert scanned PDF into searchable and selectable documents.', category: 'edit', color: 'bg-purple-600' }
        ];

       window.convertedFileUrl = null;
window.convertedFileName = null;

        // Initialize
        document.addEventListener('DOMContentLoaded', () => {
            renderTools('all');
        });

        // Render Tools Grid
        function renderTools(category) {
            const grid = document.getElementById('toolsGrid');
            grid.innerHTML = '';
            
            const filteredTools = category === 'all' ? tools : tools.filter(t => t.category === category);
            
            filteredTools.forEach(tool => {
                const card = document.createElement('div');
                card.className = 'tool-card bg-white rounded-2xl p-6 shadow-lg border border-gray-100 cursor-pointer group';
                card.onclick = () => openTool(tool);
                
                card.innerHTML = `
                    <div class="flex items-start justify-between mb-4">
                        <div class="w-14 h-14 ${tool.color} rounded-xl flex items-center justify-center text-white text-2xl shadow-lg group-hover:scale-110 transition-transform">
                            <i class="fas ${tool.icon}"></i>
                        </div>
                        ${tool.new ? '<span class="bg-green-100 text-green-700 text-xs font-bold px-2 py-1 rounded-full">NEW</span>' : ''}
                        ${tool.popular ? '<span class="bg-primary/10 text-primary text-xs font-bold px-2 py-1 rounded-full">POPULAR</span>' : ''}
                    </div>
                    <h3 class="text-lg font-bold text-gray-800 mb-2 group-hover:text-primary transition-colors">${tool.name}</h3>
                    <p class="text-gray-600 text-sm leading-relaxed">${tool.desc}</p>
                    <div class="mt-4 flex items-center text-primary font-semibold text-sm opacity-0 group-hover:opacity-100 transition-opacity">
                        Use Tool <i class="fas fa-arrow-right ml-2"></i>
                    </div>
                `;
                
                grid.appendChild(card);
            });
        }

        // Filter Tools
        function filterTools(category) {
            // Update buttons
            document.querySelectorAll('.category-btn').forEach(btn => {
                btn.classList.remove('active');
            });
            event.target.classList.add('active');
            
            // Render with animation
            const grid = document.getElementById('toolsGrid');
            grid.style.opacity = '0';
            setTimeout(() => {
                renderTools(category);
                grid.style.opacity = '1';
            }, 200);
        }

        // Open Tool Interface
        function openTool(tool) {
            currentTool = tool;
            document.getElementById('mainContent').classList.add('hidden');
            document.getElementById('toolInterface').classList.remove('hidden');
            window.scrollTo(0, 0);
            
            document.getElementById('toolIcon').innerHTML = `<i class="fas ${tool.icon}"></i>`;
            document.getElementById('toolTitle').textContent = tool.name;
            document.getElementById('toolDescription').textContent = tool.desc;
            
            // Update convert button text based on tool
            const btn = document.getElementById('convertBtn');
            if (tool.id === 'pdf-to-word') btn.textContent = 'Convert to Word';
            else if (tool.id === 'pdf-to-excel') btn.textContent = 'Convert to Excel';
            else if (tool.id === 'pdf-to-powerpoint') btn.textContent = 'Convert to PowerPoint';
            else if (tool.id === 'pdf-to-jpg') btn.textContent = 'Convert to JPG';
            else btn.textContent = 'Process PDF';
            
            resetTool();
        }

        // Show Home
        function showHome() {
            document.getElementById('mainContent').classList.remove('hidden');
            document.getElementById('toolInterface').classList.add('hidden');
            window.scrollTo(0, 0);
        }

        // Drag and Drop Handlers
        function handleDragOver(e) {
            e.preventDefault();
            e.currentTarget.classList.add('drag-active');
        }

        function handleDragLeave(e) {
            e.currentTarget.classList.remove('drag-active');
        }

        function handleDrop(e) {
            e.preventDefault();
            e.currentTarget.classList.remove('drag-active');
            const files = e.dataTransfer.files;
            if (files.length > 0 && files[0].type === 'application/pdf') {
                processFile(files[0]);
            } else {
                alert('Please upload a PDF file');
            }
        }

        function handleFileSelect(e) {
            if (e.target.files.length > 0) {
                processFile(e.target.files[0]);
            }
        }

        function processFile(file) {
            currentFile = file;
            document.getElementById('uploadArea').classList.add('hidden');
            document.getElementById('fileInfo').classList.remove('hidden');
            document.getElementById('convertBtn').classList.remove('hidden');
            
            document.getElementById('fileName').textContent = file.name;
            document.getElementById('fileSize').textContent = formatFileSize(file.size);
        }

        function removeFile() {
            currentFile = null;
            document.getElementById('fileInput').value = '';
            document.getElementById('uploadArea').classList.remove('hidden');
            document.getElementById('fileInfo').classList.add('hidden');
            document.getElementById('convertBtn').classList.add('hidden');
            document.getElementById('downloadArea').classList.add('hidden');
        }

        function formatFileSize(bytes) {
            if (bytes === 0) return '0 Bytes';
            const k = 1024;
            const sizes = ['Bytes', 'KB', 'MB', 'GB'];
            const i = Math.floor(Math.log(bytes) / Math.log(k));
            return parseFloat((bytes / Math.pow(k, i)).toFixed(2)) + ' ' + sizes[i];
        }

 async function startConversion() {
    if (!currentFile) {
        alert('Please select a PDF file first');
        return;
    }
    
    const convertBtn = document.getElementById('convertBtn');
    convertBtn.disabled = true;
    convertBtn.classList.add('opacity-50');
    
    document.getElementById('fileInfo').classList.add('hidden');
    document.getElementById('progressArea').classList.remove('hidden');
    
    try {
        const formData = new FormData();
        formData.append('file', currentFile);
        formData.append('tool', currentTool.id);
        
        // Use a relative path so it works perfectly with the server
        const response = await fetch('/api/convert', {
            method: 'POST',
            body: formData
        });
        
        if (!response.ok) throw new Error('Server error');
        
        const result = await response.json();
        
        // Progress bar animation
        document.getElementById('progressBar').style.width = '100%';
        document.getElementById('progressText').textContent = '100%';
        
        setTimeout(() => {
            document.getElementById('progressArea').classList.add('hidden');
            document.getElementById('downloadArea').classList.remove('hidden');
            
            // Store the actual server URL for the download button
            window.convertedFileUrl = result.downloadUrl;
            window.convertedFileName = result.fileName;
        }, 500);
        
    } catch (error) {
        console.error('Error:', error);
        alert('Connection failed. Make sure server.js is running!');
        resetTool();
    }
}

function downloadFile() {
    if (window.convertedFileUrl) {
        const link = document.createElement('a');
        link.href = window.convertedFileUrl;
        // This ensures the browser treats it as a Word Doc
        link.download = window.convertedFileName || 'document.docx'; 
        document.body.appendChild(link);
        link.click();
        document.body.removeChild(link);
    }
}
    // Show success message
    const btn = document.querySelector('#downloadArea button');
    const originalHTML = btn.innerHTML;
    btn.innerHTML = '<i class="fas fa-check"></i><span>Downloaded!</span>';
    btn.classList.remove('bg-green-600');
    btn.classList.add('bg-gray-600');
    
    setTimeout(() => {
        btn.innerHTML = originalHTML;
        btn.classList.remove('bg-gray-600');
        btn.classList.add('bg-green-600');
    }, 2000);


        function resetTool() {
            currentFile = null;
            document.getElementById('fileInput').value = '';
            document.getElementById('uploadArea').classList.remove('hidden');
            document.getElementById('fileInfo').classList.add('hidden');
            document.getElementById('convertBtn').classList.add('hidden');
            document.getElementById('progressArea').classList.add('hidden');
            document.getElementById('downloadArea').classList.add('hidden');
            document.getElementById('progressBar').style.width = '0%';
            document.getElementById('progressText').textContent = '0%';
        }

        // Navbar scroll effect
        window.addEventListener('scroll', () => {
            const navbar = document.getElementById('navbar');
            if (window.scrollY > 50) {
                navbar.classList.add('shadow-md');
            } else {
                navbar.classList.remove('shadow-md');
            }
        });
    </script>
</body>
